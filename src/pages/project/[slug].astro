---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import ISDLogo from "@/assets/isd-logo-white.svg";
import projectsData from "@/data/project/projects.json";

type Project = {
  title: string;
  slug: string;
  time: string;
  description: string;
  repo: string[];
};

export function getStaticPaths() {
  const projects = projectsData as Project[];
  return projects
    .filter((p) => p.slug)
    .map((p) => ({
      params: { slug: p.slug },
      props: { project: p },
    }));
}

const { project } = Astro.props as { project: Project };
---

<Layout
  title={`${project.title} — ISD`}
  description={project.description || `โปรเจกต์ ${project.title} โดยฝ่ายพัฒนาระบบสารสนเทศ (ISD)`}
>
  <main class="min-h-screen bg-[#181818] text-white">
    <section class="container m-auto px-[8%] pb-24 pt-20 lg:px-[6%]">
      <a
        href="/project"
        class="inline-flex items-center gap-2 text-sm text-[#DDDDDD] transition-colors hover:text-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 256 256"
          fill="currentColor"
        >
          <path
            d="M224,128a8,8,0,0,1-8,8H59.31l58.35,58.34a8,8,0,0,1-11.32,11.32l-72-72a8,8,0,0,1,0-11.32l72-72a8,8,0,0,1,11.32,11.32L59.31,120H216A8,8,0,0,1,224,128Z"
          ></path>
        </svg>
        กลับไปหน้า Projects
      </a>

      <div class="mt-8 overflow-hidden rounded-2xl border border-white/10 bg-black">
        <div class="flex h-56 items-center justify-center lg:h-72">
          <Image src={ISDLogo} alt="ISD Logo" class="w-24 opacity-30 lg:w-32" />
        </div>
      </div>

      <div class="mt-8">
        <div class="flex flex-wrap items-center gap-3">
          {
            project.time && (
              <span class="rounded-full bg-[#FDC648]/10 px-3 py-1 text-sm text-[#FDC648]">
                {project.time}
              </span>
            )
          }
        </div>
        <h1 class="mt-3 text-4xl font-bold lg:text-6xl">{project.title}</h1>
        {
          project.description && (
            <p class="mt-6 max-w-2xl text-base leading-relaxed text-[#DDDDDD] lg:text-lg">
              {project.description}
            </p>
          )
        }
      </div>

      {
        project.repo.length > 0 && project.repo[0] !== "no code, just design" && (
          <div class="mt-10">
            <h2 class="mb-4 text-sm font-semibold uppercase tracking-widest text-[#FDC648]">
              Source Code
            </h2>
            <div class="flex flex-wrap gap-3">
              {project.repo.map((r) => {
                const isFullUrl = r.startsWith("http");
                const label = isFullUrl ? r.replace("https://github.com/", "") : r;
                const href = isFullUrl ? r : `https://github.com/${r}`;
                return (
                  <a
                    href={href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-[#DDDDDD] transition-colors hover:border-white/30 hover:text-white"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 256 256"
                      fill="currentColor"
                    >
                      <path d="M208.31,75.68A59.78,59.78,0,0,0,202.93,28,8,8,0,0,0,196,24a59.75,59.75,0,0,0-48,24H124A59.75,59.75,0,0,0,76,24a8,8,0,0,0-6.93,4,59.78,59.78,0,0,0-5.38,47.68A58.14,58.14,0,0,0,56,104v8a56.06,56.06,0,0,0,48.44,55.47A39.8,39.8,0,0,0,96,192v8H72a24,24,0,0,1-24-24,40,40,0,0,0-40-40,8,8,0,0,0,0,16,24,24,0,0,1,24,24,40,40,0,0,0,40,40H96v16a8,8,0,0,0,16,0V192a24,24,0,0,1,48,0v40a8,8,0,0,0,16,0V192a39.8,39.8,0,0,0-8.44-24.53A56.06,56.06,0,0,0,216,112v-8A58.14,58.14,0,0,0,208.31,75.68Z" />
                    </svg>
                    {label}
                  </a>
                );
              })}
            </div>
          </div>
        )
      }
    </section>
  </main>
</Layout>
