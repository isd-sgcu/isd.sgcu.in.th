---
import Layout from "@/layouts/Layout.astro";
import ISDLogo from "@/assets/isd-logo-white.svg";
import { Image } from "astro:assets";

const roles = [
  {
    id: "pm",
    title: "Project Manager",
    icon: "ph-clipboard-text",
    description:
      "จัดการการดำเนินงานของโครงการต่าง ๆ ตั้งแต่เริ่มต้นคุยกับฝ่ายอื่น ๆ ในโครงการ วางแผนระยะเวลาทำงานต่าง ๆ จัดการคนและทรัพยากรของงาน และร่วมออกแบบระบบกับผู้พัฒนาในบางงาน ทำหน้าที่เป็น Product Owner ที่ประสานงานระหว่างทีมกับโครงการ และแก้ไขปัญหาไปร่วมกับทีม",
    interview: true,
    responsibilities: [
      "เป็นผู้ติดต่อหลักสำหรับโครงการในส่วนของฝ่าย จัดการการสื่อสารระหว่างทีมและนอกฝ่าย",
      "จัดการขอบเขต เป้าหมาย ความสำคัญ และเงื่อนไขในการประสานงานและการทำโครงการต่าง ๆ",
      "จัดการวางแผนระยะเวลา ประมาณงบ และทรัพยากรคนในการทำโครงการต่าง ๆ โดยใช้เครื่องมือจัดการโครงการที่ถนัด เช่น Notion, Trello, Linear, หรือ Jira",
      "ดูแลโครงการให้สามารถส่งงานได้ทันเวลา หรือแก้ไขปัญหาที่อาจเกิดขึ้นระหว่างทีมที่มีบทบาทหน้าที่แตกต่างกัน",
    ],
    qualifications: [
      "มีการสื่อสารที่ดี",
      "มีความเข้าใจเบื้องต้นเกี่ยวกับกระบวนการทำซอฟต์แวร์",
      "มีความสามารถในการจัดการความต้องการและแปลงให้เป็นสิ่งที่ทีมสามารถดำเนินการต่อได้",
      "มีความเข้าใจในการมอบหมายหน้าที่ที่มีความรับผิดชอบแตกต่างกันได้",
      "เข้าใจและจัดการการใช้งบประมาณของโครงการในฝ่ายได้",
    ],
    note: "ตำแหน่งนี้มีการสัมภาษณ์ในช่วงวันที่ 16 – 18 มิถุนายน",
  },
  {
    id: "frontend",
    title: "Front-end Developer",
    icon: "ph-code",
    description:
      "เป็นผู้แปลงจากงานออกแบบให้เป็นเว็บไซต์ที่ใช้งานได้จริง โดยมีความเข้าใจในระบบการทำงานของเว็บไซต์ การตรวจสอบข้อมูล การตรวจสอบสิทธ์ Best-practices ต่าง ๆ ในการสร้างเว็บไซต์ และเข้าใจเรื่องความปลอดภัยของเว็บไซต์ในเบื้องต้น",
    interview: false,
    responsibilities: [
      "สร้าง Interface ของเว็บไซต์ที่มีความ Responsive และมีประสิทธิภาพ โดยอิงตามการออกแบบของฝ่าย UX/UI",
      "ทำงานร่วมกับทีม Back-end Developer เพื่อเชื่อมต่อระหว่าง Front-end และ Back-end ให้สามารถใช้งานได้จริง",
      "ใช้ Git และ GitHub สำหรับการทำงานร่วมกันตลอดโครงการ",
      "ตรวจสอบว่าเว็บไซต์ทำงานตามที่คาดหวัง และดูดีในแต่ละอุปกรณ์",
      "เขียนโค้ดที่อ่านง่าย มีประสิทธิภาพ และผู้อื่นสามารถทำงานต่อได้ง่าย มีความรู้ใน Best Practice ต่าง ๆ ของเครื่องมือที่ใช้งาน",
    ],
    qualifications: [
      "กรณีที่มีความสามารถและเชี่ยวชาญอยู่แล้ว อาจให้เป็นหัวหน้าของทีมย่อยเพื่อจัดการและแบ่งงานให้กับหน้าใหม่ในทีม",
      "มีความเข้าใจ JavaScript, CSS, และโครงสร้างของ HTML เป็นอย่างดี",
      "มีประสบการณ์ในการใช้งาน Front-end Framework หรือ Library ต่าง ๆ ที่เกี่ยวข้อง เช่น React, Vue.js, Svelte, Angular, หรืออื่นใดที่คล้ายกันมาบ้าง",
      "มีความเข้าใจในการแปลงงานออกแบบที่ได้จาก Designer ให้เป็นเว็บไซต์ที่ใช้งานได้จริง และเป็นประโยชน์ต่อผู้ใช้งาน",
      "เข้าใจการทำให้เว็บไซต์ Responsive",
      "มีความคุ้นเคยหรือเข้าใจการใช้งาน RESTful API เพื่อทำงานร่วมกับทีม Back-end",
      "ใช้งาน Git และ GitHub ได้อย่างดี",
      "มีสกิลในการแก้ไขปัญหาเฉพาะหน้า การแก้ไขรายละเอียดเล็ก ๆ และการทำงานร่วมกัน",
    ],
    note: null,
  },
  {
    id: "backend",
    title: "Back-end Developer",
    icon: "ph-database",
    description:
      "แปลงเงื่อนไขต่าง ๆ ของเว็บไซต์ให้เป็นระบบที่ใช้งานได้จริง มีความปลอดภัย ประสิทธิภาพสูง เชื่อถือได้ และรองรับการขยายระบบเมื่อมีการใช้งานสูง โดยทำงานร่วมกับฝ่าย Front-end เพื่อให้มั่นใจว่าข้อมูลที่ส่งผ่านระหว่างกันมีความถูกต้องและปลอดภัย",
    interview: false,
    responsibilities: [
      "ออกแบบระบบที่มีความปลอดภัยสูงและรองรับผู้ใช้งานจำนวนมากได้",
      "อาจมีการให้วางแผนการทำระบบ Observability โดยทำงานร่วมกับฝ่าย DevOps หากจำเป็น",
      "ทำงานร่วมกับฝ่าย Front-end โดยสร้างคู่มือการใช้งาน API ในรูปแบบที่เป็นมาตรฐาน เช่น OpenAPI เพื่อให้มีความเข้าใจที่ตรงกันระหว่างทีม",
      "ใช้ Git และ GitHub ในการทำงานร่วมกัน",
      "ติดตามและแก้ไขปัญหาที่อาจเกิดขึ้นขณะมีการใช้งานระบบจริง",
      "เขียนเอกสารกำกับการใช้งานสำหรับ API โครงสร้างข้อมูล หรือสถาปัตยกรรมเพื่อให้ผู้อื่นในทีมสามารถทำงานร่วมกันได้ง่าย",
    ],
    qualifications: [
      "กรณีที่มีความสามารถและเชี่ยวชาญอยู่แล้ว อาจให้เป็นหัวหน้าของทีมย่อยเพื่อจัดการและแบ่งงานให้กับหน้าใหม่ในทีม",
      "มีความเข้าใจหรือมีประสบการณ์ในการใช้งานภาษาสำหรับระบบเบื้องหลัง เช่น Go, Java, PHP, Python, Node.js, Rust หรืออื่น ๆ ที่ใกล้เคียงกัน",
      "สามารถออกแบบ สร้าง และเขียนเอกสารกำกับการใช้งานที่อ่านเข้าใจง่าย และสามารถทำงานต่อได้",
      "เข้าใจในระบบความปลอดภัยของเว็บไซต์และ API เช่นการใช้ Token อย่าง JWT หรือ OAuth ในการเข้าสู่ระบบและยืนยันตัวตนผู้ใช้งาน มีมาตรการป้องกันการเข้าถึงอย่างเหมาะสม",
      "เขียนโค้ดที่มีประสิทธิภาพ มี Scalability และผู้อื่นสามารถทำงานร่วมด้วยได้",
      "ออกแบบและสื่อสารกับ DevOps ให้ระบบสามารถใช้งานได้จริง",
    ],
    note: null,
  },
  {
    id: "designer",
    title: "UX/UI Designer",
    icon: "ph-paint-brush-broad",
    description:
      "ออกแบบหน้าตาเว็บไซต์และระบบต่าง ๆ ตาม Requirements ที่ได้รับให้ออกมาดูดีและใช้งานง่าย โดยเน้นคิดจากมุมมองของผู้ใช้งานจริงเป็นหลักว่าใช้งานสะดวกและเข้าใจง่ายหรือไม่ ก่อนจะส่งต่องานให้ทีม Front-end นำไปพัฒนาเป็นเว็บไซต์ที่ใช้งานได้จริง",
    interview: true,
    responsibilities: [
      "ออกแบบหน้าตาเว็บไซต์และชิ้นงาน Asset ต่างๆ ด้วยโปรแกรม Figma ให้รองรับการใช้งานทั้งบนมือถือและคอมพิวเตอร์",
      "จัดทำ Wireframe และวางแผน User Flow การใช้งาน เพื่อให้ระบบที่ออกแบบมานั้นเข้าใจง่ายและสะดวกต่อผู้ใช้",
      "จัดทำ Design System รวมถึงสร้าง Components และ Design Tokens สำหรับแต่ละโครงการ",
      "ทำงานร่วมกับทีม Front-end เพื่อให้เว็บไซต์จริงออกมาตรงตามดีไซน์ที่วางไว้",
      "พร้อมรับฟังและปรับแก้งานออกแบบตาม Feedback ของทีม",
    ],
    qualifications: [
      "สามารถใช้งาน Figma หรือเครื่องมือออกแบบอื่นๆ ได้ (หากยังไม่คล่อง แต่ยินดีที่จะเรียนรู้ก็สามารถสมัครได้)",
      "มีความเข้าใจในเรื่องการจัดวางเลย์เอาต์ (Layout) ทฤษฎีสี (Color) และรูปแบบตัวอักษร (Typography)",
      "มีความเข้าใจและเอาใจใส่ในมุมมองของผู้ใช้งาน (Empathy)",
      "มีความเข้าใจเรื่อง Design Handoff เพื่อส่งมอบงานให้ทีม Front-end นำไปพัฒนาต่อได้อย่างราบรื่น",
      "สามารถสื่อสารและทำงานร่วมกับเพื่อนร่วมทีมได้ดี",
      "มีความรับผิดชอบ สามารถบริหารเวลาและจัดการงานให้เสร็จตามกำหนดการได้",
      "มีทัศนคติที่เปิดกว้างและพร้อมเรียนรู้สิ่งใหม่ๆ อยู่เสมอ",
      "หากมี Portfolio หรือผลงานที่เคยทำมา จะได้รับการพิจารณาเป็นพิเศษ",
    ],
    note: "ตำแหน่งนี้มีการสัมภาษณ์ในช่วงวันที่ 16 – 18 มิถุนายน",
  },
  {
    id: "devops",
    title: "DevOps Engineer",
    icon: "ph-cloud",
    description:
      "วางแผน สื่อสาร ตัดสินใจ และจัดการระบบโครงสร้างพื้นฐาน เช่น การเลือกเซิร์ฟเวอร์ การจัดการโดเมน หรือระบบอื่น ๆ เบื้องหลัง เพื่อให้ทีมพัฒนาสามารถทำงานได้ และนำโค้ดที่ได้รับจากทีมพัฒนา มา Deploy ให้ใช้งานได้จริง รองรับ CI/CD เพื่อให้ระบบมีความเสถียร รองรับผู้ใช้งานจำนวนมาก ใช้งานได้จริงตามเงื่อนไขของระบบ โดยอยู่ภายในงบประมาณที่มีให้สำหรับโครงการต่าง ๆ ในฝ่าย",
    interview: true,
    responsibilities: [
      "จัดการบำรุงรักษาโครงสร้างพื้นฐานของระบบภายในฝ่าย เพื่อให้บริการต่าง ๆ สามารถทำงานได้อย่างมีประสิทธิภาพ",
      "วาง CI/CD Pipeline ที่ build, test, deployment ได้จริง",
      "จัดการระบบอัตโนมัติเพื่อให้การทำงานง่ายขึ้น",
      "ดูแลการปรับตั้งค่าของโดเมน SSL Certificate หรือระบบที่เกี่ยวข้อง ให้พร้อมใช้งานเสมอ",
      "ตรวจตราการโหลดของเซิร์ฟเวอร์ ตรวจดูปัญหาคอขวดในระบบ เพื่อสื่อสารให้ทีมที่เกี่ยวข้องแก้ไขต่อไป",
      "แก้ปัญหาภายในระบบโครงสร้างพื้นฐานต่าง ๆ",
      "ทำงานกับระบบ Cloud Computing เจ้าต่าง ๆ เช่น Google Cloud Platform, AWS, Cloudflare อย่างเหมาะสม และอยู่ภายในงบประมาณ",
      "วางแนวทางในการส่งออกหรือนำเข้าข้อมูลเพื่อการประมวลผลตามสมควร",
    ],
    qualifications: [
      "สามารถใช้เครื่องมือ CI/CD Pipeline ได้",
      "คุ้นเคยกับการจัดการโดเมน เช่นการปรับตั้งค่าและการบริหารจัดการ",
      "Deploy ระบบที่ใช้ทรัพยากรได้อย่างคุ้มค่า",
      "สามารถติดตามการใช้ทรัพยากรและเปลี่ยนแปลงให้เหมาะสมตามสถานการณ์ได้",
      "วางแผนกับทีม Front-end & Back-end",
    ],
    note: "ตำแหน่งนี้มีการสัมภาษณ์ในช่วงวันที่ 16 – 18 มิถุนายน",
  },
];

const faqs = [
  {
    q: "ใครสามารถสมัครได้บ้าง",
    a: "นิสิตจุฬาลงกรณ์มหาวิทยาลัยระดับปริญญาตรีทุกชั้นปี รวมทั้งนิสิตชั้นปีที่ 1 ในปีการศึกษา 2569 (CU 110/Dek 69) ที่ยังไม่มีเลขประจำตัวนิสิตด้วย",
  },
  {
    q: "ต้องมีประสบการณ์หรือสกิลใด ๆ ก่อนหรือไม่",
    a: "ไม่จำเป็น ขอแค่ยินดีที่จะเรียนรู้ก็เพียงพอ",
  },
  {
    q: "การสื่อสารระหว่างทำงานเป็นภาษาอะไร",
    a: "ภาษาไทยเป็นหลัก",
  },
  {
    q: "มองหาคนแบบไหน",
    a: "เรากำลังมองหาคนที่มีความรับผิดชอบสูง และมีใจรักในการสร้างระบบเพื่อพัฒนามหาวิทยาลัย",
  },
  {
    q: "มีค่าตอบแทนไหม",
    a: "ทุกตำแหน่งไม่มีค่าตอบแทนให้ ทุกคนถือว่าเป็นอาสาสมัคร แต่จะได้รับประสบการณ์ในการทำระบบที่มีคนนับพันคนใช้งานจริง กับทีมจริง ๆ กลับไปแน่นอน",
  },
  {
    q: "ต้องมีโครงการที่เคยทำหรือมีพอร์ตฟอลิโอไหม",
    a: "ไม่จำเป็น ขอแค่อยากเรียนรู้ อยากทำงานร่วมกัน ก็เพียงพอแล้ว อาจจะมีช่วงที่ต้องเรียนรู้ด้วยตนเองบ้าง แต่ทุกคนก็เรียนรู้ไปด้วยกัน",
  },
  {
    q: "งานเยอะไหม",
    a: "ในแต่ละปีจะมีโครงการแตกต่างกันไป โดยสามารถเลือกทำโครงการใดหรือไม่ได้ตามความสมัครใจ สำหรับเนื้องานแต่ละโครงการ ขึ้นอยู่กับการตกลงความรับผิดชอบกับ PM สามารถรับมากหรือน้อยตามสะดวกได้",
  },
];
---

<Layout
  title="Join ISD"
  description="ร่วมงานกับฝ่ายพัฒนาระบบสารสนเทศ (ISD) ปีการศึกษา 2569"
>
  <main class="relative top-0 min-h-screen bg-[#181818] text-white">
