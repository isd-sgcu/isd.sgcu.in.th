<script>
  document.querySelectorAll<HTMLDetailsElement>("details").forEach((el) => {
    el.style.overflow = "hidden";
    const summary = el.querySelector("summary")!;
    summary.addEventListener("click", (e) => {
      e.preventDefault();
      if (el.open) {
        el.animate(
          [
            { height: el.scrollHeight + "px" },
            { height: summary.offsetHeight + "px" },
          ],
          { duration: 220, easing: "ease-in-out" },
        ).onfinish = () => el.removeAttribute("open");
      } else {
        el.setAttribute("open", "");
        el.animate(
          [
            { height: summary.offsetHeight + "px" },
            { height: el.scrollHeight + "px" },
          ],
          { duration: 220, easing: "ease-in-out" },
        );
      }
    });
  });

  const CLOSE = new Date("2026-06-15T23:59:59+07:00");
  if (new Date() > CLOSE) {
    document
      .querySelectorAll<HTMLElement>(".apply-btn-wrap")
      .forEach((wrap) => {
        const replacement = document.createElement("button");
        replacement.disabled = true;
        replacement.className =
          wrap.className.replace("apply-btn-wrap", "").trim() +
          " cursor-not-allowed rounded-2xl bg-white/10 px-8 py-4 text-lg font-semibold text-white/40";
        replacement.textContent = "ปิดรับสมัครแล้ว";
        wrap.replaceWith(replacement);
      });
  }
</script>
